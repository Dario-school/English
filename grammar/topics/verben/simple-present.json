{
  "id": "simple-present",
  "group": "verben",
  "title": "Simple Present",
  "description": "Aussagesätze, Verneinung und Fragen im Simple Present",
  "levels": [
    {
      "level": 1,
      "title": "Aussagesätze",
      "exercises": [
        {"type":"fill-in-the-blank","instruction":"Ergänze das Verb in der richtigen Form.","sentence":"She ___ (to play) football every day.","answer":"plays","hint":"3. Person Singular: Verb + -s"},
        {"type":"multiple-choice","instruction":"Wähle die richtige Form.","question":"They ___ to school by bus.","options":["go","goes","going","gone"],"answer":"go"},
        {"type":"fill-in-the-blank","instruction":"Ergänze das Verb.","sentence":"He ___ (to watch) TV every evening.","answer":"watches","hint":"Nach -ch: Verb + -es"},
        {"type":"multiple-choice","instruction":"Wähle die richtige Form.","question":"My sister ___ very fast.","options":["run","runs","running","ran"],"answer":"runs"},
        {"type":"fill-in-the-blank","instruction":"Ergänze das Verb.","sentence":"The dog ___ (to bark) loudly.","answer":"barks","hint":"3. Person Singular: Verb + -s"}
      ]
    },
    {
      "level": 2,
      "title": "Verneinung",
      "exercises": [
        {"type":"fill-in-the-blank","instruction":"Vereine die Verneinung.","sentence":"She ___ (not / like) pizza.","answer":"doesn't like","hint":"3. Person Singular: doesn't + Infinitiv"},
        {"type":"multiple-choice","instruction":"Wähle die richtige Verneinung.","question":"They ___ football on Sundays.","options":["don't play","doesn't play","not play","don't plays"],"answer":"don't play"},
        {"type":"fill-in-the-blank","instruction":"Verneine den Satz.","sentence":"He ___ (not / eat) meat.","answer":"doesn't eat"},
        {"type":"multiple-choice","instruction":"Wähle die richtige Form.","question":"My parents ___ in London.","options":["don't live","doesn't live","not live","don't lives"],"answer":"don't live"},
        {"type":"fill-in-the-blank","instruction":"Ergänze die Verneinung.","sentence":"It ___ (not / rain) much in summer.","answer":"doesn't rain"}
      ]
    },
    {
      "level": 3,
      "title": "Fragen",
      "exercises": [
        {"type":"multiple-choice","instruction":"Wähle die richtige Frage.","question":"___ she speak French?","options":["Do","Does","Is","Has"],"answer":"Does"},
        {"type":"fill-in-the-blank","instruction":"Bilde eine Frage.","sentence":"___ they live in London? (do/does)","answer":"Do"},
        {"type":"reorder","instruction":"Bringe die Wörter in die richtige Reihenfolge.","words":["does","she","what","eat","usually"],"answer":"What does she usually eat"},
        {"type":"multiple-choice","instruction":"Wähle die richtige Frage.","question":"___ your brother like football?","options":["Do","Does","Is","Has"],"answer":"Does"},
        {"type":"fill-in-the-blank","instruction":"Bilde eine Frage.","sentence":"Where ___ you live?","answer":"do"}
      ]
    },
    {
      "level": 4,
      "title": "Gemischte Übungen",
      "exercises": [
        {"type":"error-correction","instruction":"Finde und korrigiere den Fehler.","sentence":"She don't like cold weather.","answer":"She doesn't like cold weather."},
        {"type":"translation","instruction":"Übersetze ins Englische.","sentence":"Er spielt jeden Tag Gitarre.","answer":"He plays guitar every day."},
        {"type":"fill-in-the-blank","instruction":"Ergänze.","sentence":"How often ___ (do/does) he go swimming?","answer":"does"},
        {"type":"multiple-choice","instruction":"Wähle die richtige Form.","question":"What time ___ the film start?","options":["do","does","is","are"],"answer":"does"},
        {"type":"translation","instruction":"Übersetze ins Englische.","sentence":"Sprichst du Deutsch?","answer":"Do you speak German?"}
      ]
    },
    {
      "level": 5,
      "title": "Abschlusstest",
      "exercises": []
    }
  ]
}
